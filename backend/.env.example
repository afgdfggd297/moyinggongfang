# ═══════════════════════════════════════════════
# 墨印工坊 · 环境变量配置
# ═══════════════════════════════════════════════
# 复制此文件为 .env 后按需修改
# cp .env.example .env
#
# 所有配置项都有默认值，至少需要配置 MIMO_API_KEY
# ═══════════════════════════════════════════════


# ─── LLM 配置 ─────────────────────────────────
# API 密钥（必填）
MIMO_API_KEY=your-api-key-here

# API 地址（支持任意 OpenAI 兼容 API）
# MiMo 官方: https://token-plan-cn.xiaomimimo.com/v1
# OpenAI:    https://api.openai.com/v1
# 硅基流动:  https://api.siliconflow.cn/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型名称
# MiMo:   mimo-v2.5-pro
# OpenAI: gpt-4o, gpt-4o-mini
MIMO_LLM_MODEL=mimo-v2.5-pro

# LLM 总超时（秒）
LLM_TOTAL_TIMEOUT=120

# LLM 最大重试次数
MAX_LLM_CALL_RETRIES=3


# ─── LLM 温度 ─────────────────────────────────
# 温度范围 0.0~1.0，越高越有创意/多样性，越低越确定性
# PPT 生成属于创意任务，建议 0.7~0.9

# 方案规划温度（需要一定创造性来设计大纲结构）
LLM_PLAN_TEMPERATURE=0.8

# HTML 生成温度（需要创造性来设计视觉布局）
LLM_HTML_TEMPERATURE=0.9

# 流式输出温度（同 HTML 生成）
LLM_STREAM_TEMPERATURE=0.9


# ─── PPT 导出 ─────────────────────────────────
# 幻灯片尺寸（英寸）
# 16:9 标准: 13.333 x 7.5
# 4:3 标准:  10 x 7.5
PPT_SLIDE_W=13.333
PPT_SLIDE_H=7.5

# 截图像素尺寸（与尺寸比例匹配）
# 16:9: 1280x720 或 1920x1080
PPT_PX_W=1280
PPT_PX_H=720

# html2ppt 缩放倍数（2 = Retina 质量）
PPT_SCALE=2

# html2ppt 单页超时（秒），复杂页面可能需要更长
PPT_TIMEOUT=60

# html2ppt 可执行文件路径，留空自动从 PATH 查找
# Windows 示例: D:\nodejs\node_global\html2ppt.cmd
# Linux/Mac 留空即可（npm global 安装后自动可用）
PPT_HTML2PPT_BIN=

# 幻灯片背景色（导出时每页的底色）
PPT_BG_COLOR=#ffffff


# ─── 搜索配置 ─────────────────────────────────
# 搜索引擎 URL（国内用 Bing 中国，国外可换 Google）
SEARCH_ENGINE_URL=https://cn.bing.com/search

# 搜索请求超时（秒）
SEARCH_TIMEOUT=10

# 单次搜索最大结果数
SEARCH_MAX_RESULTS=5

# 搜索关键词最大长度（字符），超出部分截断
SEARCH_QUERY_MAX_LEN=80


# ─── WebFetch 配置 ─────────────────────────────
# 网页抓取 + AI 摘要流水线

# URL 最大长度
WEBFETCH_MAX_URL_LENGTH=2000

# 最大响应体积（MB），超出拒绝
WEBFETCH_MAX_RESPONSE_MB=10

# LRU 缓存条数
WEBFETCH_CACHE_MAXSIZE=100

# 缓存过期时间（秒），默认 15 分钟
WEBFETCH_CACHE_TTL=900

# Markdown 最大长度（KB），超出截断
WEBFETCH_MAX_MARKDOWN_KB=100

# 摘要输入截断字符数（传给 LLM 的网页内容最大长度）
WEBFETCH_SUMMARY_MAX_CHARS=8000

# 摘要 LLM 温度（需要事实准确性，建议 0.3~0.5）
WEBFETCH_SUMMARY_TEMPERATURE=0.4

# 摘要最大输出 token
WEBFETCH_SUMMARY_MAX_TOKENS=1500


# ─── 基础设施 ─────────────────────────────────

# ─── 数据库配置 ─────────────────────────────
# PostgreSQL 连接地址（异步驱动）
DATABASE_URL=postgresql+asyncpg://nlit:nlit@localhost:54432/nlit

# ─── 安全配置 ──────────────────────────────
# JWT 签名密钥（生产环境务必修改！）
SECRET_KEY=inkpress-secret-key-change-in-production
# Redis 连接地址
# 格式: redis://:password@host:port/db
REDIS_URL=redis://:deepresearch@127.0.0.1:6379/0

# PPTX 文件输出目录（相对于 backend/）
UPLOAD_DIR=./uploads

# 允许的前端域名（CORS）
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]


# ─── 环境 ─────────────────────────────────────
# 可选值: development / production / testing
ENVIRONMENT=development

# 调试模式
DEBUG=true
