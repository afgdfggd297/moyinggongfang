# ═══ PPT 导出 ═══
# PPT_SLIDE_W=13.333
# PPT_SLIDE_H=7.5
# PPT_PX_W=1280
# PPT_PX_H=720
# PPT_SCALE=2
# PPT_TIMEOUT=60
# PPT_HTML2PPT_BIN=
# PPT_BG_COLOR=#ffffff

# ═══ 搜索 ═══
# SEARCH_ENGINE_URL=https://cn.bing.com/search
# SEARCH_TIMEOUT=10
# SEARCH_MAX_RESULTS=5
# SEARCH_QUERY_MAX_LEN=80

# ═══ WebFetch ═══
# WEBFETCH_MAX_URL_LENGTH=2000
# WEBFETCH_MAX_RESPONSE_MB=10
# WEBFETCH_CACHE_MAXSIZE=100
# WEBFETCH_CACHE_TTL=900
# WEBFETCH_MAX_MARKDOWN_KB=100
# WEBFETCH_SUMMARY_MAX_CHARS=8000
# WEBFETCH_SUMMARY_TEMPERATURE=0.4
# WEBFETCH_SUMMARY_MAX_TOKENS=1500

# ═══ LLM 温度 ═══
# LLM_PLAN_TEMPERATURE=0.8
# LLM_HTML_TEMPERATURE=0.9
# LLM_STREAM_TEMPERATURE=0.9
